#Archivo .gitignore
#Este archivo indica a Git qué archivos y carpetas no deben incluirse en el repositorio.

# ===============================
# Node.js
# ===============================

node_modules/

# ===============================
# Environment variables
# ===============================

.env
.env.*
!.env.example

# ===============================
# Logs
# ===============================

logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ===============================
# Operating System
# ===============================

.DS_Store
Thumbs.db

# ===============================
# Visual Studio Code
# ===============================

.vscode/

# ===============================
# Coverage
# ===============================

coverage/

# ===============================
# Build
# ===============================

dist/
build/

# ===============================
# Temporary files
# ===============================

*.tmp
*.temp
*.txt