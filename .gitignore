#Archivo .gitignore
#Este archivo indica a Git qué archivos y carpetas no deben incluirse en el repositorio.

# ===============================
# Node.js
# ===============================

node_modules/

# ===============================
# Environment variables
# ===============================

.env
.env.*
!.env.example

# ===============================
# Logs
# ===============================

logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ===============================
# Operating System
# ===============================

.DS_Store
Thumbs.db

# ===============================
# Visual Studio Code
# ===============================

.vscode/

# ===============================
# Coverage
# ===============================

coverage/

# ===============================
# Build
# ===============================

dist/
build/

# ===============================
# Temporary files
# ===============================

*.tmp
*.temp

# ===============================
# Untracked files
# Local Development Files Only
# ===============================

# Local JSON database used during testing
api/tasks.json
# Local PostgreSQL connection module
config/db-local.js
# Database connection testing utility
public/assets/js/test-connection-db.js
